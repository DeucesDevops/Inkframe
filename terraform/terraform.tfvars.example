# Copy this file to terraform.tfvars and fill in your values.
# Never commit terraform.tfvars to source control.

aws_region   = "us-east-1"
project_name = "inkframe"
environment  = "production"

# ─── VPC ────────────────────────────────────────────────────────────────────
vpc_cidr             = "10.0.0.0/16"
private_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
public_subnet_cidrs  = ["10.0.101.0/24", "10.0.102.0/24", "10.0.103.0/24"]

# ─── EKS ────────────────────────────────────────────────────────────────────
kubernetes_version = "1.30"

# Restrict API access to your office/VPN CIDR in production
cluster_endpoint_public_access_cidrs = ["0.0.0.0/0"]

node_groups = {
  general = {
    instance_types = ["t3.medium"]
    min_size       = 2
    max_size       = 6
    desired_size   = 2
    disk_size      = 50
    capacity_type  = "ON_DEMAND"
  }
  spot = {
    instance_types = ["t3.large", "t3a.large", "m5.large"]
    min_size       = 0
    max_size       = 10
    desired_size   = 2
    disk_size      = 50
    capacity_type  = "SPOT"
  }
}

# ─── RDS ────────────────────────────────────────────────────────────────────
db_name                  = "inkframe"
db_username              = "inkframe_admin"
db_instance_class        = "db.t3.medium"
db_allocated_storage     = 20
db_max_allocated_storage = 100
db_backup_retention_days = 7
db_multi_az              = true
db_deletion_protection   = true

# ─── ElastiCache ────────────────────────────────────────────────────────────
redis_node_type       = "cache.t3.small"
redis_num_cache_nodes = 2
redis_version         = "7.1"

# ─── Domain / TLS ───────────────────────────────────────────────────────────
domain_name            = "inkframe.io"
create_acm_certificate = true
